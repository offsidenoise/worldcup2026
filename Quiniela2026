<!DOCTYPE html>
<html lang="es">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>Quiniela Profanadores Mundial 2026</title>
<style>
@import url('https://fonts.googleapis.com/css2?family=Bebas+Neue&family=Inter:wght@400;500;600;700&family=Barlow+Condensed:wght@400;600;700;800&display=swap');

:root{
  --verde:#00A550; --verde-claro:#00C85A; --dorado:#F5C518;
  --bg:#0a0e0c; --card:#121a15; --card2:#16201a;
  --texto:#EEF4F0; --dim:#7d9a85; --borde:rgba(255,255,255,0.07);
  --rojo:#FF3B5C;
  --b1:#F5C518; --b1bg:rgba(245,197,24,0.1);
  --b2:#B0BEC5; --b2bg:rgba(176,190,197,0.1);
  --b3:#D4956A; --b3bg:rgba(212,149,106,0.1);
}
*,*::before,*::after{box-sizing:border-box;margin:0;padding:0;}
body{background:var(--bg);color:var(--texto);font-family:'Inter',sans-serif;min-height:100vh;}

/* HEADER */
header{position:sticky;top:0;z-index:100;background:#fff;border-bottom:1px solid #e3e3e3;box-shadow:0 2px 14px rgba(0,0,0,0.07);}
.head-row{max-width:1000px;margin:0 auto;padding:12px 18px;display:flex;align-items:center;gap:14px;}
.head-logo{height:50px;width:auto;object-fit:contain;}
.head-titles{display:flex;flex-direction:column;line-height:1.1;flex:1;}
.head-eyebrow{font-family:'Barlow Condensed',sans-serif;font-size:10px;font-weight:700;letter-spacing:3px;text-transform:uppercase;color:var(--verde);}
.head-name{font-family:'Bebas Neue',sans-serif;font-size:27px;letter-spacing:1px;color:#15110a;line-height:1;}
.refresh-btn{display:flex;align-items:center;gap:6px;padding:9px 14px;background:#f4f4f4;border:1px solid #ddd;border-radius:8px;color:#444;font-size:12px;font-weight:500;cursor:pointer;transition:all .2s;white-space:nowrap;}
.refresh-btn:hover{border-color:var(--verde);color:var(--verde);background:#f0faf4;}
.refresh-btn:disabled{opacity:.5;cursor:not-allowed;}
.spin{animation:spin .8s linear infinite;display:inline-block;}
@keyframes spin{to{transform:rotate(360deg);}}
.tabs{max-width:1000px;margin:0 auto;display:flex;border-top:1px solid #eee;}
.tab{flex:1;padding:11px 16px;background:none;border:none;border-bottom:2px solid transparent;color:#999;font-family:'Barlow Condensed',sans-serif;font-size:14px;font-weight:700;letter-spacing:1.5px;text-transform:uppercase;cursor:pointer;transition:all .2s;}
.tab:hover{color:#444;}
.tab.active{color:var(--verde);border-bottom-color:var(--verde);}

/* STATUS */
.status{max-width:1000px;margin:14px auto 0;padding:0 18px;}
.status-in{background:var(--card);border:1px solid var(--borde);border-radius:8px;padding:8px 13px;display:flex;align-items:center;gap:8px;font-size:11px;color:var(--dim);}
.dot{width:7px;height:7px;border-radius:50%;background:var(--verde);flex-shrink:0;}
.dot.pulse{animation:dp 2s infinite;}@keyframes dp{0%,100%{opacity:1}50%{opacity:.3}}
.dot.red{background:var(--rojo);}.dot.gray{background:var(--dim);}

main{max-width:1000px;margin:14px auto 0;padding:0 18px 40px;}
.pane{display:none;}.pane.active{display:block;}
.err{background:rgba(255,59,92,.08);border:1px solid rgba(255,59,92,.25);border-radius:8px;padding:10px 14px;font-size:12px;color:#FF8FA3;margin-bottom:14px;}
.sec{display:flex;align-items:center;gap:10px;margin-bottom:14px;}
.sec-t{font-family:'Bebas Neue',sans-serif;font-size:20px;letter-spacing:1.5px;color:var(--dorado);}
.sec-l{flex:1;height:1px;background:linear-gradient(to right,var(--borde),transparent);}

/* ── RESUMEN (tab 1) ── */
.r-head{display:grid;grid-template-columns:38px 1fr 70px;padding:6px 14px;font-family:'Barlow Condensed',sans-serif;font-size:10px;font-weight:700;letter-spacing:2px;text-transform:uppercase;color:var(--dim);border-bottom:1px solid var(--borde);margin-bottom:6px;}
.r-head .r{text-align:right;}
.jcard{background:var(--card);border:1px solid var(--borde);border-radius:11px;margin-bottom:7px;overflow:hidden;transition:border-color .2s;}
.jcard:hover{border-color:rgba(0,165,80,.25);}
.jcard.top1{border-color:rgba(245,197,24,.4);background:linear-gradient(135deg,#121a15,#171f12);}
.jcard.top2{border-color:rgba(176,190,197,.25);}
.jcard.top3{border-color:rgba(212,149,106,.25);}
.jrow{display:grid;grid-template-columns:38px 1fr 70px;align-items:center;padding:12px 14px;cursor:pointer;}
.jpos{font-family:'Bebas Neue',sans-serif;font-size:24px;color:var(--dim);line-height:1;}
.top1 .jpos{color:var(--dorado);}.top2 .jpos{color:var(--b2);}.top3 .jpos{color:var(--b3);}
.jname{font-family:'Barlow Condensed',sans-serif;font-size:19px;font-weight:700;}
.top1 .jname{color:var(--dorado);}
.jpts{text-align:right;}
.jpts b{font-family:'Bebas Neue',sans-serif;font-size:25px;color:var(--verde-claro);line-height:1;display:block;}
.jpts span{font-size:9px;color:var(--dim);letter-spacing:1px;text-transform:uppercase;}
.jteams{padding:0 14px 11px;display:flex;flex-direction:column;gap:5px;}
.jteam{display:flex;align-items:center;justify-content:space-between;font-size:12.5px;padding:5px 10px;border-radius:7px;background:var(--card2);}
.jteam .tn{display:flex;align-items:center;gap:7px;font-weight:500;}
.bdot{width:8px;height:8px;border-radius:50%;flex-shrink:0;}
.bdot.b1{background:var(--b1);}.bdot.b2{background:var(--b2);}.bdot.b3{background:var(--b3);}
.jteam .tp{display:flex;align-items:center;gap:8px;}
.jteam .tpts{font-family:'Bebas Neue',sans-serif;font-size:16px;color:var(--verde-claro);}
.jteam .trank{font-size:10px;color:var(--dim);}
.jteam .tstate{font-size:10px;padding:1px 6px;border-radius:4px;}
.tstate.activo{background:rgba(0,200,90,.12);color:var(--verde-claro);}
.tstate.elim{background:rgba(255,59,92,.1);color:#FF8FA3;}
.tstate.camp{background:rgba(245,197,24,.14);color:var(--dorado);}

/* ── RANKING (tab 2) ── */
.rk-head{display:grid;grid-template-columns:42px 1fr 46px 42px 42px 50px;padding:7px 12px;font-family:'Barlow Condensed',sans-serif;font-size:10px;font-weight:700;letter-spacing:1px;text-transform:uppercase;color:var(--dim);border-bottom:1px solid var(--borde);}
.rk-head .c{text-align:center;}
.rk-row{display:grid;grid-template-columns:42px 1fr 46px 42px 42px 50px;align-items:center;padding:9px 12px;border-bottom:1px solid rgba(255,255,255,.04);font-size:13px;}
.rk-row:hover{background:var(--card2);}
.rk-pos{font-family:'Bebas Neue',sans-serif;font-size:19px;color:var(--dim);}
.rk-row.q .rk-pos{color:var(--verde-claro);}
.rk-team{display:flex;align-items:center;gap:8px;font-weight:600;font-family:'Barlow Condensed',sans-serif;font-size:15px;}
.rk-grp{font-size:9px;color:var(--dim);background:var(--card2);border-radius:3px;padding:1px 5px;}
.rk-pts{text-align:center;font-family:'Bebas Neue',sans-serif;font-size:18px;color:var(--dorado);}
.rk-c{text-align:center;color:var(--dim);font-size:12px;}
.rk-stage{text-align:center;font-size:10px;}
.stg-camp{color:var(--dorado);}.stg-elim{color:#FF8FA3;}.stg-live{color:var(--verde-claro);}
.rk-note{font-size:11px;color:var(--dim);margin-bottom:12px;line-height:1.5;}

footer{text-align:center;padding:22px;font-size:11px;color:var(--dim);border-top:1px solid var(--borde);margin-top:30px;}

@media(max-width:560px){
  .head-name{font-size:21px;}.head-logo{height:40px;}
  .refresh-btn span.txt{display:none;}
  .rk-head{grid-template-columns:34px 1fr 40px 36px 44px;}
  .rk-row{grid-template-columns:34px 1fr 40px 36px 44px;}
  .rk-head .hide-m,.rk-row .hide-m{display:none;}
}
</style>
</head>
<body>

<header>
  <div class="head-row">
    <img class="head-logo" src="https://upload.wikimedia.org/wikipedia/en/thumb/1/17/2026_FIFA_World_Cup_emblem.svg/250px-2026_FIFA_World_Cup_emblem.svg.png" alt="WC2026" onerror="this.style.display='none'">
    <div class="head-titles">
      <span class="head-eyebrow">Copa del Mundo 2026</span>
      <span class="head-name">Quiniela Profanadores</span>
    </div>
    <button class="refresh-btn" id="btn-refresh" onclick="refrescar()">
      <span id="ic">🔄</span><span class="txt" id="ic-txt">Actualizar</span>
    </button>
  </div>
  <div class="tabs">
    <button class="tab active" onclick="irTab('resumen',this)">📊 Resumen</button>
    <button class="tab" onclick="irTab('ranking',this)">🏅 Ranking de Equipos</button>
  </div>
</header>

<div class="status"><div class="status-in"><div class="dot pulse" id="dot"></div><span id="st">Cargando…</span></div></div>

<main>
  <div id="pane-resumen" class="pane active">
    <div class="sec"><span class="sec-t">📊 Resumen por Participante</span><div class="sec-l"></div></div>
    <div id="err"></div>
    <div class="r-head"><span>#</span><span>Jugador</span><span class="r">Pts</span></div>
    <div id="lista-jugadores"></div>
  </div>

  <div id="pane-ranking" class="pane">
    <div class="sec"><span class="sec-t">🏅 Ranking de los 48 Equipos</span><div class="sec-l"></div></div>
    <div class="rk-note">Orden por desempeño: ronda alcanzada en el torneo, luego criterios de desempate FIFA (puntos → enfrentamiento directo → diferencia de goles → goles a favor → conducta → Ranking FIFA). El 1er lugar otorga 48 pts a su dueño, el 48º otorga 1 pt.</div>
    <div class="rk-head">
      <span>#</span><span>Equipo</span>
      <span class="c">Pts</span>
      <span class="c hide-m">DG</span>
      <span class="c hide-m">GF</span>
      <span class="c">Ronda</span>
    </div>
    <div id="lista-ranking"></div>
  </div>
</main>

<footer>Quiniela Profanadores · Mundial 2026 · 16 participantes · $32,000 MXN · Datos en vivo: ESPN</footer>

<script>
// ══════════════════════════════════════════════════════
// PARTICIPANTES  (nombres en español)
// ══════════════════════════════════════════════════════
const JUGADORES = [
  {nombre:"Lino",    b1:"Brasil",         b2:"Suiza",           b3:"Arabia Saudita"},
  {nombre:"Tonic",   b1:"Francia",        b2:"Japón",           b3:"Ghana"},
  {nombre:"Sanro",   b1:"Inglaterra",     b2:"Noruega",         b3:"Escocia"},
  {nombre:"Tinho",   b1:"Argentina",      b2:"Corea del Sur",   b3:"Bosnia y Herzegovina"},
  {nombre:"Dilfer",  b1:"España",         b2:"Austria",         b3:"Catar"},
  {nombre:"Diablo",  b1:"Alemania",       b2:"Suecia",          b3:"Panamá"},
  {nombre:"Serazzi", b1:"Portugal",       b2:"Ecuador",         b3:"Iraq"},
  {nombre:"Barrera", b1:"Países Bajos",   b2:"Turquía",         b3:"Sudáfrica"},
  {nombre:"Mach",    b1:"Uruguay",        b2:"República Checa", b3:"DR Congo"},
  {nombre:"Hernan",  b1:"Bélgica",        b2:"Canadá",          b3:"Uzbekistán"},
  {nombre:"Chase",   b1:"Croacia",        b2:"Australia",       b3:"Jordania"},
  {nombre:"Tafich",  b1:"Marruecos",      b2:"Egipto",          b3:"Cabo Verde"},
  {nombre:"Pirata",  b1:"Estados Unidos", b2:"Costa de Marfil", b3:"Curaçao"},
  {nombre:"Marvin",  b1:"México",         b2:"Paraguay",        b3:"Haití"},
  {nombre:"Trish",   b1:"Colombia",       b2:"Túnez",           b3:"Irán"},
  {nombre:"Richar",  b1:"Senegal",        b2:"Argelia",         b3:"Nueva Zelanda"},
];

// ══════════════════════════════════════════════════════
// GRUPOS, FIFA RANKING  (nombres en español)
// ══════════════════════════════════════════════════════
const GRUPOS = {
  A:['México','Sudáfrica','Corea del Sur','República Checa'],
  B:['Canadá','Bosnia y Herzegovina','Catar','Suiza'],
  C:['Brasil','Marruecos','Haití','Escocia'],
  D:['Estados Unidos','Paraguay','Australia','Turquía'],
  E:['Alemania','Curaçao','Costa de Marfil','Ecuador'],
  F:['Países Bajos','Japón','Suecia','Túnez'],
  G:['Bélgica','Egipto','Irán','Nueva Zelanda'],
  H:['España','Cabo Verde','Arabia Saudita','Uruguay'],
  I:['Francia','Senegal','Iraq','Noruega'],
  J:['Argentina','Argelia','Austria','Jordania'],
  K:['Portugal','DR Congo','Uzbekistán','Colombia'],
  L:['Inglaterra','Croacia','Ghana','Panamá'],
};
const GRUPO_DE = {};
Object.entries(GRUPOS).forEach(([g,eqs])=>eqs.forEach(e=>GRUPO_DE[e]=g));

// Ranking FIFA oficial (1 abr 2026) — menor número = mejor
const FIFA_RANK = {
  'Francia':1,'España':2,'Argentina':3,'Inglaterra':4,'Portugal':5,
  'Brasil':6,'Países Bajos':7,'Marruecos':8,'Bélgica':9,'Alemania':10,
  'Croacia':11,'Colombia':13,'Senegal':14,'México':15,'Estados Unidos':16,
  'Uruguay':17,'Japón':18,'Suiza':19,'Irán':21,'Turquía':22,
  'Austria':23,'Ecuador':24,'Corea del Sur':25,'Australia':27,'Egipto':28,
  'Argelia':29,'Canadá':30,'Noruega':31,'Panamá':33,'Costa de Marfil':34,
  'Suecia':38,'Paraguay':40,'República Checa':41,'Escocia':43,'Túnez':45,
  'DR Congo':46,'Uzbekistán':50,'Catar':55,'Iraq':57,'Sudáfrica':60,
  'Arabia Saudita':61,'Jordania':63,'Bosnia y Herzegovina':65,'Cabo Verde':68,'Ghana':74,
  'Curaçao':82,'Haití':83,'Nueva Zelanda':85,
};

const TODOS_EQUIPOS = Object.values(GRUPOS).flat();

// ══════════════════════════════════════════════════════
// ESTADO POR EQUIPO
//  st[eq] = {gf,ga,pts,gd,yellow,red,jugados, ronda, etapa, eliminado, campeon}
// ══════════════════════════════════════════════════════
let st = {};
function initState(){
  st = {};
  TODOS_EQUIPOS.forEach(e=>{
    st[e]={gf:0,ga:0,pts:0,gd:0,yellow:0,red:0,jugados:0,
           ronda:0,etapa:'Fase de Grupos',eliminado:false,campeon:false,
           subcampeon:false,tercero:false,cuarto:false};
  });
}

// Orden de rondas (mayor = más lejos)
const RONDA={grupos:0,r32:1,r16:2,qf:3,sf:4,tercer:5,final:6};
const conductScore=(y,r)=>y*1+r*3;  // menor es mejor

// ══════════════════════════════════════════════════════
// ESPN  (igual técnica que tu otra app: API + proxy CORS)
// ══════════════════════════════════════════════════════
const ESPN='https://site.api.espn.com/apis/site/v2/sports/soccer/fifa.world';
// Varios proxies CORS en cadena — si uno falla, intenta el siguiente
const PROXIES=[
  u=>u,                                                   // 1) directo (funciona en dominios reales)
  u=>'https://corsproxy.io/?url='+encodeURIComponent(u),  // 2) corsproxy.io
  u=>'https://api.allorigins.win/raw?url='+encodeURIComponent(u), // 3) allorigins
  u=>'https://thingproxy.freeboard.io/fetch/'+u,          // 4) thingproxy
];
async function espnFetch(url){
  for(const wrap of PROXIES){
    try{
      const r=await fetch(wrap(url));
      if(r.ok) return r;
    }catch(e){}
  }
  throw new Error('Todos los proxies fallaron');
}

function normEquipo(name){
  if(!name) return null;
  const k=name.toLowerCase().normalize('NFD').replace(/[\u0300-\u036f]/g,'').replace(/['.&-]/g,' ').replace(/\s+/g,' ').trim();
  const M={
    'brazil':'Brasil','france':'Francia','england':'Inglaterra','argentina':'Argentina',
    'spain':'España','germany':'Alemania','portugal':'Portugal','netherlands':'Países Bajos','holland':'Países Bajos',
    'uruguay':'Uruguay','belgium':'Bélgica','croatia':'Croacia','morocco':'Marruecos',
    'united states':'Estados Unidos','usa':'Estados Unidos','usmnt':'Estados Unidos',
    'mexico':'México','colombia':'Colombia','senegal':'Senegal','switzerland':'Suiza',
    'japan':'Japón','norway':'Noruega','south korea':'Corea del Sur','korea republic':'Corea del Sur','republic of korea':'Corea del Sur',
    'austria':'Austria','sweden':'Suecia','ecuador':'Ecuador','turkey':'Turquía','turkiye':'Turquía',
    'czechia':'República Checa','czech republic':'República Checa','canada':'Canadá','australia':'Australia',
    'egypt':'Egipto','ivory coast':'Costa de Marfil','cote d ivoire':'Costa de Marfil','cote divoire':'Costa de Marfil',
    'paraguay':'Paraguay','tunisia':'Túnez','algeria':'Argelia','saudi arabia':'Arabia Saudita','ksa':'Arabia Saudita','saudi':'Arabia Saudita',
    'ghana':'Ghana','scotland':'Escocia','bosnia':'Bosnia y Herzegovina','bosnia and herzegovina':'Bosnia y Herzegovina','bosnia herzegovina':'Bosnia y Herzegovina','bih':'Bosnia y Herzegovina',
    'qatar':'Catar','panama':'Panamá','iraq':'Iraq','south africa':'Sudáfrica',
    'dr congo':'DR Congo','congo dr':'DR Congo','democratic republic of congo':'DR Congo','democratic republic of the congo':'DR Congo',
    'uzbekistan':'Uzbekistán','jordan':'Jordania','cape verde':'Cabo Verde','cabo verde':'Cabo Verde',
    'curacao':'Curaçao','haiti':'Haití','iran':'Irán','ir iran':'Irán','islamic republic of iran':'Irán',
    'new zealand':'Nueva Zelanda',
  };
  if(M[k]) return M[k];
  for(const x in M){ if(k===x||k.includes(x)||x.includes(k)) return M[x]; }
  return null;
}

function clasificarRonda(txt){
  const r=(txt||'').toLowerCase();
  if(r.includes('third')||r.includes('3rd')) return 'tercer';
  if(r.includes('semi')) return 'sf';
  if(r.includes('quarter')) return 'qf';
  if(r.includes('round of 16')||r.includes('last 16')) return 'r16';
  if(r.includes('round of 32')||r.includes('last 32')) return 'r32';
  if(r.includes('final')) return 'final';
  return 'grupos';
}

async function refrescar(){
  const btn=document.getElementById('btn-refresh'), ic=document.getElementById('ic'), ictxt=document.getElementById('ic-txt');
  if(btn.disabled) return;
  btn.disabled=true; ic.innerHTML='<span class="spin">⚽</span>'; ictxt.textContent='Cargando…';
  setStatus('🔎 Obteniendo resultados de ESPN…','pulse'); document.getElementById('err').innerHTML='';

  try{
    const rangos=['20260611-20260627','20260628-20260719'];
    const eventos=[];
    for(const d of rangos){
      try{const r=await espnFetch(`${ESPN}/scoreboard?dates=${d}&limit=100`); if(!r.ok) continue;
        const j=await r.json(); (j.events||[]).forEach(e=>eventos.push(e));}catch(e){}
    }
    if(eventos.length===0) throw new Error('Sin datos de ESPN');
    computar(eventos);
    guardarCache();
    const jug=eventos.filter(e=>e.status?.type?.completed===true).length;
    setStatus(`✅ Actualizado · ${jug} partidos jugados`,'green');
  }catch(err){
    console.error(err);
    const tieneCache=cargarCache();
    if(tieneCache){
      document.getElementById('err').innerHTML=`<div class="err">⚠️ Sin conexión ahora — mostrando últimos resultados guardados.</div>`;
      setStatus('📦 Mostrando datos guardados','gray');
    }else{
      document.getElementById('err').innerHTML=`<div class="err">⚠️ ${err.message} — abre la app en tu sitio publicado para cargar resultados en vivo.</div>`;
      setStatus('⚠️ No se pudieron cargar resultados','red');
    }
  }
  btn.disabled=false; ic.textContent='🔄'; ictxt.textContent='Actualizar';
  render();
}

// Procesa los eventos de ESPN y llena st[]
function computar(eventos){
  initState();
  let campeon=null,subcampeon=null,tercero=null,cuarto=null;

  for(const ev of eventos){
    const comp=ev.competitions?.[0]; if(!comp) continue;
    const cs=comp.competitors||[]; if(cs.length<2) continue;
    const hC=cs.find(c=>c.homeAway==='home')||cs[0];
    const aC=cs.find(c=>c.homeAway==='away')||cs[1];
    const t1=normEquipo(hC.team?.displayName||hC.team?.name||'');
    const t2=normEquipo(aC.team?.displayName||aC.team?.name||'');
    if(!t1||!t2||st[t1]===undefined||st[t2]===undefined) continue;

    const rTxt=(comp.notes&&comp.notes[0]?.headline)||ev.name||'';
    const rKey=clasificarRonda(rTxt);
    const rIdx=RONDA[rKey]??0;
    // marca la ronda más avanzada alcanzada
    [t1,t2].forEach(t=>{ if(rIdx>st[t].ronda) st[t].ronda=rIdx; });

    if(ev.status?.type?.completed!==true) continue;
    const g1=parseInt(hC.score)||0, g2=parseInt(aC.score)||0;

    if(rKey==='grupos'){
      // Acumula tabla de grupos (puntos, gf, ga)
      st[t1].gf+=g1; st[t1].ga+=g2; st[t1].jugados++;
      st[t2].gf+=g2; st[t2].ga+=g1; st[t2].jugados++;
      if(g1>g2){ st[t1].pts+=3; }
      else if(g2>g1){ st[t2].pts+=3; }
      else { st[t1].pts++; st[t2].pts++; }
    }

    // Ganador / perdedor (penales vía flag winner de ESPN)
    let gan=null,per=null;
    if(hC.winner===true||aC.winner===true){ gan=hC.winner?t1:t2; per=hC.winner?t2:t1; }
    else if(g1!==g2){ gan=g1>g2?t1:t2; per=g1>g2?t2:t1; }

    if(rKey!=='grupos'&&per){ st[per].eliminado=true; st[per].etapa=etapaNombre(rKey,false); }
    if(rKey==='final'){ if(gan){campeon=gan;} if(per){subcampeon=per;} }
    if(rKey==='tercer'){ if(gan){tercero=gan;} if(per){cuarto=per;} }
  }

  if(campeon){ st[campeon].campeon=true; st[campeon].etapa='Campeón'; st[campeon].eliminado=false; }
  if(subcampeon){ st[subcampeon].subcampeon=true; st[subcampeon].etapa='Subcampeón'; st[subcampeon].eliminado=true; }
  if(tercero){ st[tercero].tercero=true; st[tercero].etapa='3er Lugar'; st[tercero].eliminado=true; }
  if(cuarto){ st[cuarto].cuarto=true; st[cuarto].etapa='4to Lugar'; st[cuarto].eliminado=true; }

  // Calcula GD y etapa para los que siguen vivos
  TODOS_EQUIPOS.forEach(e=>{
    st[e].gd=st[e].gf-st[e].ga;
    if(!st[e].eliminado&&!st[e].campeon&&!st[e].subcampeon&&!st[e].tercero&&!st[e].cuarto){
      st[e].etapa=etapaNombre(ronKeyDe(st[e].ronda),true);
    }
  });
}

function ronKeyDe(idx){ return Object.keys(RONDA).find(k=>RONDA[k]===idx)||'grupos'; }
function etapaNombre(rKey,vivo){
  const M={grupos:'Fase de Grupos',r32:'Dieciseisavos',r16:'Octavos',qf:'Cuartos',sf:'Semifinal',final:'Final',tercer:'3er Lugar'};
  return M[rKey]||'Fase de Grupos';
}

// ══════════════════════════════════════════════════════
// RANKING DE 48 EQUIPOS  (ronda alcanzada → criterios FIFA)
// ══════════════════════════════════════════════════════
function calcularRanking(){
  // valor de la etapa: campeón > subcampeón > 3º > 4º > QF > R16 > R32 > grupos
  function etapaValor(e){
    const s=st[e];
    if(s.campeon) return 100;
    if(s.subcampeon) return 99;
    if(s.tercero) return 98;
    if(s.cuarto) return 97;
    // vivos o eliminados en KO según ronda alcanzada
    return s.ronda; // 0..6
  }

  // H2H entre un subconjunto (solo partidos de grupos entre ellos)
  // Como ESPN no expone fácil el detalle por-partido de grupos aquí,
  // usamos la diferencia de goles y goles a favor globales del grupo
  // como criterio principal de desempate (paso 2 FIFA), y FIFA rank (paso 3).
  function cmp(a,b){
    const va=etapaValor(a), vb=etapaValor(b);
    if(vb!==va) return vb-va;                       // ronda / posición final
    // mismos: aplicar criterios FIFA
    if(st[b].pts!==st[a].pts) return st[b].pts-st[a].pts;          // puntos
    if(st[b].gd!==st[a].gd) return st[b].gd-st[a].gd;              // diferencia de goles
    if(st[b].gf!==st[a].gf) return st[b].gf-st[a].gf;              // goles a favor
    const cA=conductScore(st[a].yellow,st[a].red);
    const cB=conductScore(st[b].yellow,st[b].red);
    if(cA!==cB) return cA-cB;                                       // conducta (menor mejor)
    return (FIFA_RANK[a]||999)-(FIFA_RANK[b]||999);                // Ranking FIFA
  }

  const orden=[...TODOS_EQUIPOS].sort(cmp);
  // posición 1..48  →  puntos 48..1
  return orden.map((e,i)=>({equipo:e, pos:i+1, puntos:48-i, ...st[e]}));
}

// mapa equipo → puntos (de su posición en el ranking)
function puntosPorEquipo(){
  const rk=calcularRanking();
  const m={};
  rk.forEach(r=>m[r.equipo]=r.puntos);
  return m;
}

// ══════════════════════════════════════════════════════
// RENDER
// ══════════════════════════════════════════════════════
function setStatus(msg,type){
  document.getElementById('st').textContent=msg;
  const d=document.getElementById('dot'); d.className='dot';
  if(type==='pulse') d.classList.add('pulse');
  else if(type==='red') d.classList.add('red');
  else if(type==='gray') d.classList.add('gray');
}

function render(){ renderResumen(); renderRanking(); }

function renderResumen(){
  const ptsEq=puntosPorEquipo();
  const rkPos={}; calcularRanking().forEach(r=>rkPos[r.equipo]=r.pos);

  const filas=JUGADORES.map(j=>{
    const eqs=[{n:j.b1,b:1},{n:j.b2,b:2},{n:j.b3,b:3}].map(x=>({
      ...x, pts:ptsEq[x.n]||0, rank:rkPos[x.n]||'-', est:st[x.n]
    }));
    const total=eqs.reduce((s,e)=>s+e.pts,0);
    const mejor=Math.min(...eqs.map(e=>rkPos[e.n]||999));
    return {nombre:j.nombre, eqs, total, mejor};
  }).sort((a,b)=> b.total!==a.total ? b.total-a.total : a.mejor-b.mejor);

  document.getElementById('lista-jugadores').innerHTML=filas.map((j,i)=>{
    const pos=i+1, cls=pos===1?'top1':pos===2?'top2':pos===3?'top3':'';
    const medal=pos===1?'🥇':pos===2?'🥈':pos===3?'🥉':pos;
    const teams=j.eqs.map(e=>{
      const s=e.est;
      let badge,txt;
      if(s.campeon){badge='camp';txt='🏆 Campeón';}
      else if(s.eliminado){badge='elim';txt=s.etapa;}
      else{badge='activo';txt=s.etapa;}
      return `<div class="jteam">
        <span class="tn"><span class="bdot b${e.b}"></span>${e.n}</span>
        <span class="tp">
          <span class="tstate ${badge}">${txt}</span>
          <span class="trank">#${e.rank}</span>
          <span class="tpts">${e.pts}</span>
        </span>
      </div>`;
    }).join('');
    return `<div class="jcard ${cls}">
      <div class="jrow">
        <div class="jpos">${medal}</div>
        <div class="jname">${j.nombre}</div>
        <div class="jpts"><b>${j.total}</b><span>pts</span></div>
      </div>
      <div class="jteams">${teams}</div>
    </div>`;
  }).join('');
}

function renderRanking(){
  const rk=calcularRanking();
  document.getElementById('lista-ranking').innerHTML=rk.map(r=>{
    const s=r;
    let stage,scls;
    if(s.campeon){stage='🏆 Campeón';scls='stg-camp';}
    else if(s.eliminado){stage=s.etapa;scls='stg-elim';}
    else{stage=s.etapa;scls='stg-live';}
    // marca de "clasificación" visual para top de cada grupo no aplica aquí; resaltamos vivos
    const q = !s.eliminado ? 'q' : '';
    return `<div class="rk-row ${q}">
      <div class="rk-pos">${r.pos}</div>
      <div class="rk-team">${r.equipo} <span class="rk-grp">${GRUPO_DE[r.equipo]||''}</span></div>
      <div class="rk-pts">${r.puntos}</div>
      <div class="rk-c hide-m">${s.gd>0?'+':''}${s.gd}</div>
      <div class="rk-c hide-m">${s.gf}</div>
      <div class="rk-stage ${scls}">${stage}</div>
    </div>`;
  }).join('');
}

function irTab(id,el){
  document.querySelectorAll('.pane').forEach(p=>p.classList.remove('active'));
  document.querySelectorAll('.tab').forEach(t=>t.classList.remove('active'));
  document.getElementById('pane-'+id).classList.add('active');
  el.classList.add('active');
}

// ── CACHÉ en localStorage (para no ver ceros si el fetch falla) ──
const CACHE_KEY='quiniela_profanadores_st_v1';
function guardarCache(){
  try{ localStorage.setItem(CACHE_KEY, JSON.stringify(st)); }catch(e){}
}
function cargarCache(){
  try{
    const raw=localStorage.getItem(CACHE_KEY);
    if(!raw) return false;
    const obj=JSON.parse(raw);
    if(obj && typeof obj==='object'){ st=obj; return true; }
  }catch(e){}
  return false;
}

// INIT
initState();
cargarCache();            // si hay datos guardados, mostrarlos de inmediato
setStatus('Cargando resultados en vivo…','pulse');
render();
refrescar();              // y refrescar en vivo en segundo plano
</script>
